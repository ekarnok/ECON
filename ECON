import random

class BuildingEnvelope:
    def __init__(self, material, orientation, insulation_value, height):
        self.material = material          # e.g., "Adobe", "Bamboo", "Stone"
        self.orientation = orientation    # 0-360 degrees
        self.insulation = insulation_value # 0.0 to 1.0
        self.height = height              # elevation in meters
        self.integrity = 100.0            # Starting health
        self.efficiency_score = 0.0

class EnvironmentSimulator:
    def __init__(self, biome):
        self.biome = biome
        self.year = 0
        # Stressor intensity (0-10)
        self.hazards = {'flood': 2, 'wind': 5, 'heat': 8} 

    def run_year_cycle(self, building):
        self.year += 1
        
        # 1. Thermal Stress (Calculation: Heat vs Insulation)
        heat_damage = (self.hazards['heat'] * (1 - building.insulation)) * 0.5
        
        # 2. Wind Stress (Calculation: Height increases wind vulnerability)
        wind_damage = (self.hazards['wind'] * (building.height * 0.2))
        
        # 3. Flood Stress (Calculation: Height mitigates flood)
        flood_damage = max(0, self.hazards['flood'] - (building.height * 0.5))

        # Apply degradation
        total_wear = heat_damage + wind_damage + flood_damage
        building.integrity -= total_wear
        
        return total_wear

# --- Game Loop Logic ---

def play_simulation():
    # Player Input Simulation
    print("--- Welcome to Vernacula Designer ---")
    my_build = BuildingEnvelope(material="Adobe", orientation=180, insulation_value=0.8, height=1.2)
    sim = EnvironmentSimulator(biome="Arid Desert")

    checkpoints = [5, 10, 20, 50]
    
    print(f"Starting 50-year simulation for {my_build.material} structure...")
    
    while sim.year < 50:
        wear = sim.run_year_cycle(my_build)
        
        if sim.year in checkpoints:
            print(f"\n[YEAR {sim.year} REPORT]")
            print(f"Structural Integrity: {max(0, round(my_build.integrity, 2))}%")
            
            if my_build.integrity <= 0:
                print("CRITICAL FAILURE: The building has collapsed.")
                break
            
            # Feedback Score Metrics
            health_score = (my_build.insulation * 100) - (sim.hazards['heat'] * 2)
            print(f"Occupant Comfort Score: {health_score}/100")

    # Win Condition Check
    if my_build.integrity > 80 and sim.year == 50:
        print("\n🏆 WIN CONDITION MET: Your vernacular design endured for half a century!")
    elif my_build.integrity > 0:
        print("\n📈 DESIGN SURVIVED: But significant retrofitting is required.")

if __name__ == "__main__":
    play_simulation()
